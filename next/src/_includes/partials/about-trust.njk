{%- set t = i18n[lang] -%}
<section class="section section--bg-soft">
  <div class="container">
    <div class="section-head" style="text-align: center; max-width: 720px; margin: 0 auto 2.4rem;">
      <p class="kicker">{{ t.aboutPage.credentialsEyebrow }}</p>
      <h2>{{ t.aboutPage.credentialsTitle }}</h2>
      <p class="muted">{{ t.aboutPage.credentialsLead }}</p>
    </div>
    <div class="credentials-grid">
      <article class="credential-card">
        <div class="credential-badge" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 4l10 4v8c0 6-4 10-10 12-6-2-10-6-10-12V8l10-4z"/>
            <path d="M11.5 16.5l3.2 3.2 6.3-6.3"/>
          </svg>
        </div>
        <h3>{{ t.aboutPage.credAnttTitle }}</h3>
        <p class="muted small">{{ t.aboutPage.credAnttBody }}</p>
      </article>
      <article class="credential-card">
        <div class="credential-badge" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="16" cy="16" r="11"/>
            <path d="M6 16h20M16 6c3 3 3 17 0 20M16 6c-3 3-3 17 0 20"/>
          </svg>
        </div>
        <h3>{{ t.aboutPage.credAblaTitle }}</h3>
        <p class="muted small">{{ t.aboutPage.credAblaBody }}</p>
      </article>
      <article class="credential-card">
        <div class="credential-badge" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="9" width="24" height="18" rx="3"/>
            <path d="M9 9V6a7 7 0 0 1 14 0v3"/>
            <circle cx="16" cy="18" r="2.5"/>
          </svg>
        </div>
        <h3>{{ t.aboutPage.credDpvatTitle }}</h3>
        <p class="muted small">{{ t.aboutPage.credDpvatBody }}</p>
      </article>
      <article class="credential-card">
        <div class="credential-badge" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="4" width="22" height="24" rx="2.5"/>
            <path d="M10 12h12M10 17h12M10 22h7"/>
          </svg>
        </div>
        <h3>{{ t.aboutPage.credLgpdTitle }}</h3>
        <p class="muted small">{{ t.aboutPage.credLgpdBody }}</p>
      </article>
      <article class="credential-card">
        <div class="credential-badge" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 3h14l4 5v18a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/>
            <path d="M11 15l4 4 7-7"/>
          </svg>
        </div>
        <h3>{{ t.aboutPage.credNfeTitle }}</h3>
        <p class="muted small">{{ t.aboutPage.credNfeBody }}</p>
      </article>
      <article class="credential-card">
        <div class="credential-badge" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="16" cy="11" r="5"/>
            <path d="M5 28a11 11 0 0 1 22 0"/>
          </svg>
        </div>
        <h3>{{ t.aboutPage.credCheckTitle }}</h3>
        <p class="muted small">{{ t.aboutPage.credCheckBody }}</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container container--narrow">
    <div class="section-head" style="text-align: center; max-width: 680px; margin: 0 auto 2rem;">
      <p class="kicker">{{ t.aboutPage.howWeWorkEyebrow }}</p>
      <h2>{{ t.aboutPage.howWeWorkTitle }}</h2>
    </div>
    <ol class="how-list">
      <li class="how-item"><span class="how-num num">01</span><p>{{ t.aboutPage.howWeWorkStep1 }}</p></li>
      <li class="how-item"><span class="how-num num">02</span><p>{{ t.aboutPage.howWeWorkStep2 }}</p></li>
      <li class="how-item"><span class="how-num num">03</span><p>{{ t.aboutPage.howWeWorkStep3 }}</p></li>
      <li class="how-item"><span class="how-num num">04</span><p>{{ t.aboutPage.howWeWorkStep4 }}</p></li>
    </ol>
  </div>
</section>

<section class="section section--bg-soft">
  <div class="container container--narrow">
    <div class="section-head" style="text-align: center; max-width: 680px; margin: 0 auto 2rem;">
      <p class="kicker">{{ t.aboutPage.teamEyebrow }}</p>
      <h2>{{ t.aboutPage.teamTitle }}</h2>
      <p class="muted">{{ t.aboutPage.teamBody }}</p>
    </div>
    <dl class="team-stats">
      <div><dt class="num">12</dt><dd class="muted small">{{ t.aboutPage.teamFleetSize }}</dd></div>
      <div><dt class="num">8</dt><dd class="muted small">{{ t.aboutPage.teamYearsAvg }}</dd></div>
      <div><dt class="num">4</dt><dd class="muted small">{{ t.aboutPage.teamLanguages }}</dd></div>
      <div><dt class="num">BR · UY · PY · AR</dt><dd class="muted small">{{ t.aboutPage.teamCoverage }}</dd></div>
    </dl>
  </div>
</section>
