{%- set t = i18n[lang] -%}
<section class="section section--bg-navy vip-section">
  <div class="container">
    <div class="vip-layout">
      <div class="vip-copy reveal-up">
        <p class="kicker">{{ t.vipBusiness.eyebrow }}</p>
        <h2>{{ t.vipBusiness.title }}</h2>
        <p class="lead">{{ t.vipBusiness.lead }}</p>
        <div class="cta-strip-actions" style="margin-top: 1.6rem;">
          <a class="btn btn-dark btn-arrow" href="/{{ lang }}/contact/?topic=executive">{{ t.vipBusiness.ctaPrimary }}</a>
          <a class="btn btn-secondary" href="/{{ lang }}/partners/">{{ t.vipBusiness.ctaSecondary }}</a>
        </div>
      </div>
      <ul class="vip-list reveal-stagger">
        <li><span class="vip-marker num">01</span><div><h3>{{ t.vipBusiness.b1Title }}</h3><p>{{ t.vipBusiness.b1Body }}</p></div></li>
        <li><span class="vip-marker num">02</span><div><h3>{{ t.vipBusiness.b2Title }}</h3><p>{{ t.vipBusiness.b2Body }}</p></div></li>
        <li><span class="vip-marker num">03</span><div><h3>{{ t.vipBusiness.b3Title }}</h3><p>{{ t.vipBusiness.b3Body }}</p></div></li>
        <li><span class="vip-marker num">04</span><div><h3>{{ t.vipBusiness.b4Title }}</h3><p>{{ t.vipBusiness.b4Body }}</p></div></li>
        <li><span class="vip-marker num">05</span><div><h3>{{ t.vipBusiness.b5Title }}</h3><p>{{ t.vipBusiness.b5Body }}</p></div></li>
        <li><span class="vip-marker num">06</span><div><h3>{{ t.vipBusiness.b6Title }}</h3><p>{{ t.vipBusiness.b6Body }}</p></div></li>
      </ul>
    </div>
  </div>
</section>
