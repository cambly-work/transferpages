{%- set t = i18n[lang] -%}
<section class="section how-it-works" aria-labelledby="process-heading">
  <div class="container">
    <header class="section-head section-head--centered">
      <p class="kicker">{{ t.howItWorks.subtitle }}</p>
      <h2 id="process-heading">{{ t.howItWorks.title }}</h2>
    </header>
    <ol class="steps steps--6 reveal-stagger">
      <li class="step">
        <span class="step-num num">01</span>
        <h3>{{ t.howItWorks.step1Title }}</h3>
        <p>{{ t.howItWorks.step1Body }}</p>
      </li>
      <li class="step">
        <span class="step-num num">02</span>
        <h3>{{ t.howItWorks.step2Title }}</h3>
        <p>{{ t.howItWorks.step2Body }}</p>
      </li>
      <li class="step">
        <span class="step-num num">03</span>
        <h3>{{ t.howItWorks.step3Title }}</h3>
        <p>{{ t.howItWorks.step3Body }}</p>
      </li>
      <li class="step">
        <span class="step-num num">04</span>
        <h3>{{ t.howItWorks.step4Title }}</h3>
        <p>{{ t.howItWorks.step4Body }}</p>
      </li>
      <li class="step">
        <span class="step-num num">05</span>
        <h3>{{ t.howItWorks.step5Title }}</h3>
        <p>{{ t.howItWorks.step5Body }}</p>
      </li>
      <li class="step">
        <span class="step-num num">06</span>
        <h3>{{ t.howItWorks.step6Title }}</h3>
        <p>{{ t.howItWorks.step6Body }}</p>
      </li>
    </ol>
  </div>
</section>
