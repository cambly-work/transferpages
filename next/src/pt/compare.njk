            <td>{{ row.uber.pt }}</td>
            <td>{{ row.blacklane.pt }}</td>
            <td>{{ row.taxi.pt }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section section--bg-navy">
