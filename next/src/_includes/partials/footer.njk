{%- set t = i18n[lang] -%}
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="logo" href="/{{ lang }}/">
          {{ site.name }}
          <small>{{ t.brand.tagline }}</small>
        </a>
        <p>{{ t.footer.description }}</p>
      </div>
      <div>
        <h4>{{ t.footer.sections }}</h4>
        <ul>
          {%- for item in nav.footer %}
          <li><a href="/{{ lang }}/{{ item.href }}">{{ t.nav[item.key] }}</a></li>
          {%- endfor %}
        </ul>
      </div>
      <div>
        <h4>{{ t.footer.contacts }}</h4>
        <ul>
          <li><a href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">WhatsApp</a></li>
          <li><a href="{{ site.contacts.telegramUrl }}" target="_blank" rel="noopener">Telegram</a></li>
          <li><a href="/{{ lang }}/contact/">{{ t.footer.request }}</a></li>
        </ul>
      </div>
      <div>
        <h4>{{ t.footer.languages }}</h4>
        <ul>
          {%- for code in site.locales %}
          <li><a href="/{{ code }}/">{{ i18n[code].label }}</a></li>
          {%- endfor %}
        </ul>
      </div>
    </div>
    <div class="footer-fineprint">
      <span>&copy; <span data-year>{{ "" | year }}</span> {{ t.copyright }}</span>
      <span>{{ site.contacts.whatsappUrl | replace("https://", "") }}</span>
    </div>
  </div>
</footer>
