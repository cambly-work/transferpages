{# Renders a single icon by name. Usage:
   {% set iconName = "route" %}{% include "partials/icon.njk" %}
   All icons share a single style: line, 1.6px stroke, currentColor, 24×24. #}
<svg class="icon icon--{{ iconName }}" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
{%- if iconName == "route" -%}
  <path d="M 5 19 L 5 5 L 12 12 L 19 5 L 19 19"/>
  <circle cx="5" cy="5" r="1.4" fill="currentColor" stroke="none"/>
  <circle cx="19" cy="5" r="1.4" fill="currentColor" stroke="none"/>
  <circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/>
{%- elif iconName == "car" -%}
  <path d="M 4 13 L 5.5 7.5 A 1 1 0 0 1 6.5 7 L 17.5 7 A 1 1 0 0 1 18.5 7.5 L 20 13"/>
  <path d="M 3 13 L 21 13 L 21 17 A 1 1 0 0 1 20 18 L 18 18 L 18 16 L 6 16 L 6 18 L 4 18 A 1 1 0 0 1 3 17 Z"/>
  <circle cx="7" cy="16" r="1.2"/>
  <circle cx="17" cy="16" r="1.2"/>
{%- elif iconName == "suitcase" -%}
  <rect x="4" y="8" width="16" height="12" rx="1.5"/>
  <path d="M 9 8 L 9 5 A 1 1 0 0 1 10 4 L 14 4 A 1 1 0 0 1 15 5 L 15 8"/>
  <line x1="12" y1="11" x2="12" y2="17"/>
{%- elif iconName == "driver" -%}
  <circle cx="12" cy="8" r="3.5"/>
  <path d="M 5 20 A 7 7 0 0 1 19 20"/>
{%- elif iconName == "doc" -%}
  <path d="M 7 3 L 14 3 L 18 7 L 18 20 A 1 1 0 0 1 17 21 L 7 21 A 1 1 0 0 1 6 20 L 6 4 A 1 1 0 0 1 7 3 Z"/>
  <path d="M 14 3 L 14 7 L 18 7"/>
  <line x1="9" y1="12" x2="15" y2="12"/>
  <line x1="9" y1="15" x2="15" y2="15"/>
  <line x1="9" y1="18" x2="13" y2="18"/>
{%- elif iconName == "airplane" -%}
  <path d="M 12 3 L 14 11 L 21 13 L 14 14 L 12 21 L 10 14 L 3 13 L 10 11 Z"/>
{%- elif iconName == "border" -%}
  <line x1="3" y1="12" x2="21" y2="12"/>
  <line x1="6" y1="9" x2="6" y2="15"/>
  <line x1="18" y1="9" x2="18" y2="15"/>
  <circle cx="12" cy="12" r="2.2"/>
{%- elif iconName == "receipt" -%}
  <path d="M 6 3 L 18 3 L 18 21 L 15 19 L 12 21 L 9 19 L 6 21 Z"/>
  <line x1="9" y1="9" x2="15" y2="9"/>
  <line x1="9" y1="13" x2="15" y2="13"/>
{%- elif iconName == "coin" -%}
  <circle cx="12" cy="12" r="8"/>
  <path d="M 12 7 L 12 17 M 9.5 9.5 A 2.5 2.5 0 1 1 12 14 A 2.5 2.5 0 1 0 14.5 17"/>
{%- elif iconName == "clock" -%}
  <circle cx="12" cy="12" r="8"/>
  <path d="M 12 7 L 12 12 L 15.5 14"/>
{%- elif iconName == "phone" -%}
  <path d="M 5 4 A 1 1 0 0 1 6 3 L 8.5 3 L 10 7 L 8 9 A 11 11 0 0 0 15 16 L 17 14 L 21 15.5 L 21 18 A 1 1 0 0 1 20 19 A 16 16 0 0 1 5 4 Z"/>
{%- elif iconName == "email" -%}
  <rect x="3" y="5" width="18" height="14" rx="1.5"/>
  <path d="M 3 7 L 12 13 L 21 7"/>
{%- elif iconName == "chat" -%}
  <path d="M 4 5 A 1 1 0 0 1 5 4 L 19 4 A 1 1 0 0 1 20 5 L 20 16 A 1 1 0 0 1 19 17 L 10 17 L 6 21 L 6 17 L 5 17 A 1 1 0 0 1 4 16 Z"/>
{%- elif iconName == "live" -%}
  <circle cx="12" cy="12" r="3.5" fill="currentColor" stroke="none"/>
  <circle cx="12" cy="12" r="7" opacity="0.4"/>
  <circle cx="12" cy="12" r="10" opacity="0.15"/>
{%- elif iconName == "check" -%}
  <path d="M 5 12 L 10 17 L 19 7"/>
{%- elif iconName == "arrow-right" -%}
  <line x1="4" y1="12" x2="20" y2="12"/>
  <path d="M 14 6 L 20 12 L 14 18"/>
{%- elif iconName == "filter" -%}
  <path d="M 3 5 L 21 5 L 14 13 L 14 19 L 10 21 L 10 13 Z"/>
{%- elif iconName == "search" -%}
  <circle cx="11" cy="11" r="6.5"/>
  <line x1="16" y1="16" x2="21" y2="21"/>
{%- elif iconName == "globe" -%}
  <circle cx="12" cy="12" r="8"/>
  <path d="M 4 12 L 20 12 M 12 4 A 11 11 0 0 1 12 20 A 11 11 0 0 1 12 4"/>
{%- endif -%}
</svg>
