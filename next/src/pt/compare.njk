            <th>Uber Black</th>
            <th>Blacklane</th>
            <th>Táxi</th>
          </tr>
        </thead>
        <tbody>
          {%- for row in compare.rows %}
          <tr>
            <th scope="row">{{ row.label.pt }}</th>
