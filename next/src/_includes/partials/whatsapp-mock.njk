{%- set onlineLabel = { "ru": "онлайн", "pt": "online", "en": "online" } -%}
<div class="whatsapp-mock" aria-hidden="true">
  <div class="whatsapp-mock-header">
    <div class="whatsapp-mock-avatar">M</div>
    <div>
      <div class="whatsapp-mock-name">Morrison Premium Transfer</div>
      <div class="whatsapp-mock-status">{{ onlineLabel[lang] }}</div>
    </div>
  </div>
  <div class="whatsapp-mock-chat">
    {%- for b in bubbles[lang] %}
    <div class="whatsapp-bubble whatsapp-bubble--{{ b.side }}">
      {{ b.text }}
      <span class="whatsapp-bubble-time">{{ b.time }}</span>
    </div>
    {%- endfor %}
  </div>
</div>
