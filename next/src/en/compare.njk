<section class="hero">
  <div class="container container--narrow">
    <p class="kicker reveal-up">Compare</p>
    <h1 class="reveal-up">How we differ<br>from taxi and ride-sharing.</h1>
    <p class="lead reveal-up">8 criteria clients usually decide on. No marketing inflation — each cell reflects real market practice.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="compare-wrap">
      <table class="compare-table">
        <thead>
          <tr>
            <th></th>
            <th class="compare-us">Morrison</th>
            <th>Uber Black</th>
            <th>Blacklane</th>
            <th>Taxi</th>
          </tr>
        </thead>
        <tbody>
          {%- for row in compare.rows %}
          <tr>
            <th scope="row">{{ row.label.en }}</th>
            <td class="compare-us">{{ row.morrison.en }}</td>
            <td>{{ row.uber.en }}</td>
            <td>{{ row.blacklane.en }}</td>
            <td>{{ row.taxi.en }}</td>
          </tr>
          {%- endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section section--bg-navy">
  <div class="container container--narrow" style="text-align: center;">
