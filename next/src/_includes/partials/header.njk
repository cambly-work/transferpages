{%- set t = i18n[lang] -%}
<a class="skip-link" href="#main">{{ t.meta.skip }}</a>
<header class="site-header">
  <div class="container nav-wrap">
    <a class="logo" href="/{{ lang }}/" aria-label="{{ site.name }}">
      <svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true">
        <path d="M 5.5 24.5 L 5.5 9 L 16 19.5 L 26.5 9 L 26.5 24.5" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="5.5" cy="9" r="2.2" fill="currentColor"/>
        <circle cx="26.5" cy="9" r="2.2" fill="currentColor"/>
        <circle cx="16" cy="19.5" r="2.2" fill="currentColor"/>
        <circle cx="5.5" cy="24.5" r="1.4" fill="currentColor"/>
        <circle cx="26.5" cy="24.5" r="1.4" fill="currentColor"/>
      </svg>
      <span class="logo-text">
        <strong>Morrison</strong>
        <small>Premium Transfer</small>
      </span>
    </a>
    <nav class="site-nav" aria-label="{{ t.meta.primaryNav }}">
      <button class="nav-toggle" aria-expanded="false" aria-label="{{ t.meta.openMenu }}">Menu</button>
      <ul class="nav-list">
        {%- for item in nav.primary %}
        {%- set href = "/" + lang + "/" + item.href -%}
        <li><a href="{{ href }}">{{ t.nav[item.key] }}</a></li>
        {%- endfor %}
      </ul>
    </nav>
    <button type="button" class="theme-toggle" data-theme-toggle aria-label="{{ t.ui.themeDark }}">
      <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
        <circle cx="12" cy="12" r="4" fill="currentColor"/>
        <g stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="12" y1="2" x2="12" y2="5"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="2" y1="12" x2="5" y2="12"/>
          <line x1="19" y1="12" x2="22" y2="12"/>
          <line x1="4.5" y1="4.5" x2="6.7" y2="6.7"/>
          <line x1="17.3" y1="17.3" x2="19.5" y2="19.5"/>
          <line x1="4.5" y1="19.5" x2="6.7" y2="17.3"/>
          <line x1="17.3" y1="6.7" x2="19.5" y2="4.5"/>
        </g>
      </svg>
      <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
        <path d="M 20 14 A 8 8 0 1 1 10 4 A 6.5 6.5 0 0 0 20 14 Z" fill="currentColor"/>
      </svg>
    </button>
    <div class="lang-switch" aria-label="{{ t.meta.languages }}">
      {%- for code in site.locales %}
      <a href="/{{ code }}/{{ slug + '/' if slug else '' }}"{% if code == lang %} class="active"{% endif %}>{{ i18n[code].short }}</a>
      {%- endfor %}
    </div>
  </div>
</header>
