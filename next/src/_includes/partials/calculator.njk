{%- set t = i18n[lang] -%}
{%- set cityCoords = {
  "gru": { x: 725, y: 100, anchor: "start" },
  "gig": { x: 920, y: 60,  anchor: "end" },
  "cwb": { x: 550, y: 220, anchor: "end" },
  "fln": { x: 600, y: 345, anchor: "start" },
  "nvt": { x: 590, y: 300, anchor: "end" },
  "bnu": { x: 605, y: 320, anchor: "start" },
  "poa": { x: 430, y: 490, anchor: "end" },
  "igr": { x: 220, y: 230, anchor: "start" },
  "asu": { x: 50,  y: 210, anchor: "start" },
  "mvd": { x: 120, y: 760, anchor: "start" },
  "pde": { x: 200, y: 760, anchor: "start" }
} -%}
<section class="section section--bg-soft" id="calculator">
  <div class="container container--narrow">
    <p class="kicker" style="text-align: center;">{{ t.calc.title }}</p>
    <h2 style="text-align: center;">{{ t.calc.subtitle }}</h2>

    <div class="calc-map" data-calc-map>
      <svg viewBox="0 0 1000 850" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Brazil & Mercosur coverage map">
        <defs>
          <pattern id="map-grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.04)" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#map-grid)"/>
        {%- for pair in routes.pairs %}
        <line class="map-line"
              data-map-line="{{ pair.from }}-{{ pair.to }}"
              x1="{{ cityCoords[pair.from].x }}" y1="{{ cityCoords[pair.from].y }}"
              x2="{{ cityCoords[pair.to].x }}" y2="{{ cityCoords[pair.to].y }}"/>
        {%- endfor %}
        {%- for city in routes.cities %}
        {%- set c = cityCoords[city.id] %}
        <g data-map-city="{{ city.id }}">
          <circle class="map-city" cx="{{ c.x }}" cy="{{ c.y }}" r="5"/>
          <text class="map-label"
                x="{{ c.x + (8 if c.anchor == 'start' else -8) }}"
                y="{{ c.y + 4 }}"
                text-anchor="{{ c.anchor }}">{{ city.name[lang] }}</text>
        </g>
        {%- endfor %}
      </svg>
    </div>

    <form class="calc" data-calculator data-lang="{{ lang }}" novalidate>
      <div class="calc-row">
        <label class="field">
          <span>{{ t.calc.from }}</span>
          <select name="from" data-calc-from required>
            <option value="">—</option>
            {%- for city in routes.cities %}
            <option value="{{ city.id }}">{{ city.name[lang] }}</option>
            {%- endfor %}
          </select>
        </label>
        <label class="field">
          <span>{{ t.calc.to }}</span>
          <select name="to" data-calc-to required>
            <option value="">—</option>
            {%- for city in routes.cities %}
            <option value="{{ city.id }}">{{ city.name[lang] }}</option>
            {%- endfor %}
          </select>
        </label>
      </div>
      <div class="calc-row">
        <label class="field">
          <span>{{ t.calc.passengers }}</span>
          <select name="pax" data-calc-pax>
            <option value="1">1</option>
            <option value="2" selected>2</option>
            <option value="3">3</option>
            <option value="4">4</option>
            <option value="5">5</option>
            <option value="6">6</option>
            <option value="7">7</option>
            <option value="8">8+</option>
          </select>
        </label>
        <label class="field">
          <span>{{ t.calc.luggage }}</span>
          <select name="luggage" data-calc-luggage>
            <option value="standard">{{ t.calc.luggageStandard }}</option>
            <option value="extra">{{ t.calc.luggageExtra }}</option>
            <option value="oversized">{{ t.calc.luggageOversized }}</option>
          </select>
        </label>
      </div>
      <button type="submit" class="btn btn-dark btn-arrow calc-submit">{{ t.calc.cta }}</button>

      <div class="calc-result" data-calc-result hidden>
        <div class="calc-result-state" data-calc-state-error hidden></div>
        <div class="calc-result-state" data-calc-state-ok hidden>
          <p class="eyebrow" data-calc-route-name></p>
          <div class="calc-result-grid">
            <div><dt>{{ t.calc.distance }}</dt><dd data-calc-distance class="num"></dd></div>
            <div><dt>{{ t.calc.duration }}</dt><dd data-calc-duration class="num"></dd></div>
            <div><dt>{{ t.calc.result }}</dt><dd data-calc-price class="num"></dd></div>
          </div>
          <p class="muted small">{{ t.calc.perKm }}</p>
          <a class="btn btn-dark btn-arrow" data-calc-confirm href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">{{ t.calc.confirm }}</a>
        </div>
      </div>
    </form>

    <script type="application/json" data-calc-data>
      {
        "pairs": [
          {%- for pair in routes.pairs -%}
          {
            "from": "{{ pair.from }}",
            "to": "{{ pair.to }}",
            "km": {{ pair.km }},
            "durationMin": {{ pair.durationMin }},
            "priceMin": {{ pair.priceMin }},
            "priceMax": {{ pair.priceMax }},
            "slug": "{{ pair.slug }}"
          }{% if not loop.last %},{% endif %}
          {%- endfor -%}
        ],
        "cities": {
          {%- for city in routes.cities -%}
          "{{ city.id }}": "{{ city.name[lang] }}"{% if not loop.last %},{% endif %}
          {%- endfor -%}
        },
        "messages": {
          "pickFirst": "{{ t.calc.pickFirst }}",
          "sameCity": "{{ t.calc.sameCity }}",
          "notFound": "{{ t.calc.notFound }}"
        },
        "whatsapp": "{{ site.contacts.whatsappUrl }}",
        "lang": "{{ lang }}"
      }
    </script>
  </div>
</section>
