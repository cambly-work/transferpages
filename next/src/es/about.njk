---
slug: "about"
permalink: "/es/about/index.html"
title: "About | Morrison Premium Transfer"
description: "Who Morrison Premium Transfer is: private transfers across Brazil and Mercosur with a fixed price and conditions confirmed before departure."
schema: "Service"
serviceType: "Private passenger transfer"
breadcrumbs:
  - { name: "Inicio", path: "/es/" }
  - { name: "About", path: "/es/about/" }
---
<section class="hero">
  <div class="container container--narrow">
    <p class="kicker">{{ t.aboutPage.eyebrow }}</p>
    <h1>{{ t.aboutPage.title }}</h1>
    <p class="lead">{{ t.aboutPage.lead }}</p>
    <div class="hero-actions">
      <a class="btn btn-dark btn-arrow" href="/es/contact/">Get in touch</a>
      <a class="btn btn-secondary" href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>

<section class="section section--bg-soft">
  <div class="container">
    <h2 style="text-align: center;">{{ t.aboutPage.valuesTitle }}</h2>
    <div class="value-grid">
      <article class="value-card">
        <h3>{{ t.aboutPage.val1Title }}</h3>
        <p>{{ t.aboutPage.val1Body }}</p>
      </article>
      <article class="value-card">
        <h3>{{ t.aboutPage.val2Title }}</h3>
        <p>{{ t.aboutPage.val2Body }}</p>
      </article>
      <article class="value-card">
        <h3>{{ t.aboutPage.val3Title }}</h3>
        <p>{{ t.aboutPage.val3Body }}</p>
      </article>
      <article class="value-card">
        <h3>{{ t.aboutPage.val4Title }}</h3>
        <p>{{ t.aboutPage.val4Body }}</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container container--narrow">
    <h2 style="text-align: center;">At a glance</h2>
    <dl class="facts-dl">
      <div><dt>Company</dt><dd>{{ site.legal.entityName }}</dd></div>
      <div><dt>CNPJ</dt><dd>{{ t.footer.cnpjValue }}</dd></div>
      <div><dt>Base</dt><dd>{{ site.legal.city }} / {{ site.legal.state }}, Brazil</dd></div>
      <div><dt>Coverage</dt><dd>Brazil, Uruguay, Paraguay, Argentina</dd></div>
      <div><dt>Languages</dt><dd>Português · Русский · English</dd></div>
      <div><dt>Channels</dt><dd>WhatsApp · Telegram · Email · Site</dd></div>
    </dl>
  </div>
</section>

<section class="cta-strip">
  <div class="container container--narrow">
    <h2>Ready to plan a trip?</h2>
    <div class="cta-strip-actions">
      <a class="btn btn-dark btn-arrow" href="/es/contact/">Open the form</a>
      <a class="btn btn-secondary" href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>
