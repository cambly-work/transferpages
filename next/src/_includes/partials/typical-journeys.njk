{%- set t = i18n[lang] -%}
<section class="section typical-journeys-section">
  <div class="container">
    <header class="section-head section-head--centered">
      <p class="kicker">{{ t.typicalJourneys.eyebrow }}</p>
      <h2>{{ t.typicalJourneys.title }}</h2>
      <p class="muted">{{ t.typicalJourneys.lead }}</p>
    </header>
    <ol class="journey-list reveal-stagger">
      <li class="journey">
        <span class="journey-format num">{{ t.typicalJourneys.j1Format }}</span>
        <h3>{{ t.typicalJourneys.j1Route }}</h3>
        <p class="muted">{{ t.typicalJourneys.j1Body }}</p>
      </li>
      <li class="journey">
        <span class="journey-format num">{{ t.typicalJourneys.j2Format }}</span>
        <h3>{{ t.typicalJourneys.j2Route }}</h3>
        <p class="muted">{{ t.typicalJourneys.j2Body }}</p>
      </li>
      <li class="journey">
        <span class="journey-format num">{{ t.typicalJourneys.j3Format }}</span>
        <h3>{{ t.typicalJourneys.j3Route }}</h3>
        <p class="muted">{{ t.typicalJourneys.j3Body }}</p>
      </li>
      <li class="journey">
        <span class="journey-format num">{{ t.typicalJourneys.j4Format }}</span>
        <h3>{{ t.typicalJourneys.j4Route }}</h3>
        <p class="muted">{{ t.typicalJourneys.j4Body }}</p>
      </li>
      <li class="journey">
        <span class="journey-format num">{{ t.typicalJourneys.j5Format }}</span>
        <h3>{{ t.typicalJourneys.j5Route }}</h3>
        <p class="muted">{{ t.typicalJourneys.j5Body }}</p>
      </li>
    </ol>
  </div>
</section>
