{%- set t = i18n[lang] -%}
<section class="section capabilities-section">
  <div class="container">
    <header class="section-head section-head--centered">
      <p class="kicker">{{ t.capabilities.eyebrow }}</p>
      <h2>{{ t.capabilities.title }}</h2>
      <p class="muted">{{ t.capabilities.lead }}</p>
    </header>
    <div class="capability-grid reveal-stagger">
      <article class="capability">
        <div class="capability-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        </div>
        <h3>{{ t.capabilities.c1Title }}</h3>
        <p class="muted small">{{ t.capabilities.c1Body }}</p>
      </article>
      <article class="capability">
        <div class="capability-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/></svg>
        </div>
        <h3>{{ t.capabilities.c2Title }}</h3>
        <p class="muted small">{{ t.capabilities.c2Body }}</p>
