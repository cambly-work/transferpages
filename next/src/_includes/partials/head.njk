{%- set t = i18n[lang] -%}
{%- set localePath = "/" + lang + "/" -%}
{%- set canonical = site.domain + localePath + (slug + "/" if slug else "") -%}
{%- set ogVariant = "default" -%}
{%- if ogImage -%}
  {%- set ogVariant = ogImage -%}
{%- elif slug -%}
  {%- if "blog" in slug -%}{%- set ogVariant = "blog" -%}
  {%- elif "fleet" in slug -%}{%- set ogVariant = "fleet" -%}
  {%- elif slug == "compare" -%}{%- set ogVariant = "compare" -%}
  {%- elif slug == "cases" -%}{%- set ogVariant = "cases" -%}
  {%- endif -%}
{%- endif -%}
{%- set ogImageUrl = site.domain + "/assets/images/og-" + ogVariant + ".svg" -%}
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="{{ canonical }}">
<meta property="og:image" content="{{ ogImageUrl }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:locale" content="{{ t.htmlLang | replace('-', '_') }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="twitter:image" content="{{ ogImageUrl }}">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#ffffff">
<meta name="view-transition" content="same-origin">
<link rel="canonical" href="{{ canonical }}">
{%- for code in site.locales %}
<link rel="alternate" hreflang="{{ i18n[code].hreflang }}" href="{{ site.domain }}/{{ code }}/{{ slug + '/' if slug else '' }}">
{%- endfor %}
<link rel="alternate" hreflang="x-default" href="{{ site.domain }}/{{ site.defaultLocale }}/{{ slug + '/' if slug else '' }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap"></noscript>
<link rel="stylesheet" href="/assets/style.css">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="manifest" href="/manifest.webmanifest">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Morrison">
{%- if site.sentry and site.sentry.dsn %}
<meta name="sentry-dsn" content="{{ site.sentry.dsn }}">
{%- endif %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "{{ site.domain }}/#business",
  "name": "{{ site.name }}",
  "url": "{{ site.domain }}/{{ lang }}/",
  "image": "{{ ogImageUrl }}",
  "description": "{{ description }}",
  "telephone": "+{{ site.contacts.whatsapp }}",
  "email": "{{ site.contacts.email }}",
  "priceRange": "$$$",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ site.legal.city }}",
    "addressRegion": "{{ site.legal.state }}",
    "addressCountry": "{{ site.legal.country }}"
  },
  "areaServed": [
    {%- for area in site.areaServed -%}
    { "@type": "Country", "name": "{{ area.name }}" }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ],
  "sameAs": [
    "{{ site.contacts.whatsappUrl }}",
    "{{ site.contacts.telegramUrl }}"
  ],
  "founder": { "@type": "Organization", "name": "{{ site.legal.entityName }}" },
  "foundingDate": "{{ site.legal.founded }}",
  "knowsLanguage": ["pt", "ru", "en"]
}
</script>
{%- if schema == "Service" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "{{ serviceType or title }}",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "provider": { "@id": "{{ site.domain }}/#business" },
  "areaServed": [
    {%- for area in site.areaServed -%}
    { "@type": "Country", "name": "{{ area.name }}" }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ],
  "url": "{{ canonical }}"
}
</script>
{%- endif %}
{%- if slug and slug.startsWith and slug.startsWith("blog/") and post %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ post.title[lang] | dump | safe }},
  "description": {{ post.excerpt[lang] | dump | safe }},
  "datePublished": "{{ post.date }}",
  "dateModified": "{{ post.date }}",
  "author": { "@type": "Organization", "name": "{{ site.name }}" },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "logo": { "@type": "ImageObject", "url": "{{ site.domain }}/favicon.svg" }
  },
  "image": "{{ ogImageUrl }}",
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ canonical }}" },
  "articleSection": {{ post.category[lang] | dump | safe }},
  "inLanguage": "{{ t.htmlLang }}"
}
</script>
{%- endif %}
{%- if faq %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for item in faq -%}
    {
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} }
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
{%- endif %}
{%- if breadcrumbs %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {%- for crumb in breadcrumbs -%}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": {{ crumb.name | dump | safe }},
      "item": "{{ site.domain }}{{ crumb.path }}"
    }{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
{%- endif %}
<script>
  // Apply theme synchronously before paint to avoid FOUC
  (function(){
    try {
      var t = localStorage.getItem('preferredTheme');
      if (!t && window.matchMedia('(prefers-color-scheme: dark)').matches) t = 'dark';
      if (t === 'dark' || t === 'light') document.documentElement.setAttribute('data-theme', t);
    } catch(e){}
  })();
</script>
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.ga4 }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  // GA4 consent mode v2 — denied by default, upgraded by cookie banner accept.
  gtag('consent', 'default', {
    'ad_storage': 'denied',
    'ad_user_data': 'denied',
    'ad_personalization': 'denied',
    'analytics_storage': 'denied',
    'wait_for_update': 500
  });
  gtag('config', '{{ site.analytics.ga4 }}', { 'anonymize_ip': true });
</script>
