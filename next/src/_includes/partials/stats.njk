{%- set t = i18n[lang] -%}
<section class="section stats-section">
  <div class="container">
    <header class="stats-head reveal-up">
      <p class="kicker">{{ t.stats.eyebrow }}</p>
      <h2>{{ t.stats.title }}</h2>
    </header>
    <div class="stats-grid reveal-stagger">
      <article class="stat">
        <div class="stat-icon">{% set iconName = "globe" %}{% include "partials/icon.njk" %}</div>
        <span class="stat-figure"><span class="num count-up" data-count-to="{{ t.stats.metric1Value }}" data-count-duration="900">0</span>{{ t.stats.metric1Suffix }}</span>
        <p class="stat-caption">{{ t.stats.metric1Label }}</p>
      </article>
      <article class="stat">
        <div class="stat-icon">{% set iconName = "route" %}{% include "partials/icon.njk" %}</div>
        <span class="stat-figure"><span class="num count-up" data-count-to="{{ t.stats.metric2Value }}" data-count-duration="900">0</span>{{ t.stats.metric2Suffix }}</span>
        <p class="stat-caption">{{ t.stats.metric2Label }}</p>
      </article>
      <article class="stat">
        <div class="stat-icon">{% set iconName = "chat" %}{% include "partials/icon.njk" %}</div>
        <span class="stat-figure"><span class="num count-up" data-count-to="{{ t.stats.metric3Value }}" data-count-duration="900">0</span>{{ t.stats.metric3Suffix }}</span>
        <p class="stat-caption">{{ t.stats.metric3Label }}</p>
      </article>
      <article class="stat">
        <div class="stat-icon">{% set iconName = "clock" %}{% include "partials/icon.njk" %}</div>
        <span class="stat-figure"><span class="num count-up" data-count-to="{{ t.stats.metric4Value }}" data-count-duration="900">0</span>{{ t.stats.metric4Suffix }}</span>
        <p class="stat-caption">{{ t.stats.metric4Label }}</p>
      </article>
    </div>
  </div>
</section>
