      <a class="btn btn-dark btn-arrow" href="/{{ lang }}/contact/">Согласовать маршрут</a>
      <a class="btn btn-secondary" href="#calculator">Узнать цену</a>
    </div>
    <dl class="metric-strip reveal-up">
      <div><dt>Плечи</dt><dd><span class="num">400–1500</span><span class="unit">км</span></dd></div>
      <div><dt>Согласование</dt><dd><span class="num">до выезда</span></dd></div>
      <div><dt>Запас</dt><dd><span class="num">2-3</span><span class="unit">сценария</span></dd></div>
      <div><dt>Ответ</dt><dd><span class="num">&lt; 1</span><span class="unit">час</span></dd></div>
