---
slug: "about"
permalink: "/es/about/index.html"
title: "Acerca | Morrison Premium Transfer"
description: "Quiénes somos: Morrison Premium Transfer — transfers privados por Brasil y Mercosur con precio fijo y condiciones confirmadas antes de salir."
schema: "Service"
serviceType: "Private passenger transfer"
breadcrumbs:
  - { name: "Inicio", path: "/es/" }
  - { name: "Acerca", path: "/es/about/" }
---
<section class="hero">
  <div class="container container--narrow">
    <p class="kicker">{{ t.aboutPage.eyebrow }}</p>
    <h1>{{ t.aboutPage.title }}</h1>
    <p class="lead">{{ t.aboutPage.lead }}</p>
    <div class="hero-actions">
      <a class="btn btn-dark btn-arrow" href="/es/contact/">Hablar con nosotros</a>
      <a class="btn btn-secondary" href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">WhatsApp</a>
    </div>
    {% set heroPhoto = { src: "bc-night-skyline", alt: "Costa de Santa Catarina de noche — rascacielos desde la orilla rocosa", ratio: "21-9", modifier: "hero-photo--overlay" } %}
    {% include "partials/hero-photo.njk" %}
  </div>
</section>

<section class="section section--bg-soft">
  <div class="container">
    <h2 style="text-align: center;">{{ t.aboutPage.valuesTitle }}</h2>
    <div class="value-grid">
      <article class="value-card">
        <h3>{{ t.aboutPage.val1Title }}</h3>
        <p>{{ t.aboutPage.val1Body }}</p>
      </article>
      <article class="value-card">
        <h3>{{ t.aboutPage.val2Title }}</h3>
        <p>{{ t.aboutPage.val2Body }}</p>
      </article>
      <article class="value-card">
        <h3>{{ t.aboutPage.val3Title }}</h3>
        <p>{{ t.aboutPage.val3Body }}</p>
      </article>
      <article class="value-card">
        <h3>{{ t.aboutPage.val4Title }}</h3>
        <p>{{ t.aboutPage.val4Body }}</p>
      </article>
    </div>
  </div>
</section>

<section class="section">
  <div class="container container--narrow">
    <h2 style="text-align: center;">Ficha rápida</h2>
    <dl class="facts-dl">
      <div><dt>Empresa</dt><dd>{{ site.legal.entityName }}</dd></div>
      <div><dt>CNPJ</dt><dd>{{ t.footer.cnpjValue }}</dd></div>
      <div><dt>Sede</dt><dd>{{ site.legal.city }} / {{ site.legal.state }}, Brasil</dd></div>
      <div><dt>Cobertura</dt><dd>Brasil, Uruguay, Paraguay, Argentina</dd></div>
      <div><dt>Idiomas</dt><dd>Português · Русский · English · Español</dd></div>
      <div><dt>Canales</dt><dd>WhatsApp · Telegram · Email · Sitio</dd></div>
    </dl>
  </div>
</section>

{% include "partials/about-trust.njk" %}

<section class="cta-strip">
  <div class="container container--narrow">
    <h2>¿Listo para planear el viaje?</h2>
    <div class="cta-strip-actions">
      <a class="btn btn-dark btn-arrow" href="/es/contact/">Abrir formulario</a>
      <a class="btn btn-secondary" href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>
