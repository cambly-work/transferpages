{%- set t = i18n[lang] -%}
{# Floating chat widget — opens a chat-style overlay with a few canned prompts,
   then hands off to WhatsApp with the chosen topic pre-filled in the message. #}
<div class="chat-widget" data-chat-widget>
  <button class="chat-widget-toggle" type="button" data-chat-toggle aria-label="{{ t.chat.openLabel }}" aria-expanded="false">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12a9 9 0 0 1-13.5 7.8L3 21l1.3-4.5A9 9 0 1 1 21 12z"/>
    </svg>
    <span class="chat-widget-pulse" aria-hidden="true"></span>
  </button>
  <div class="chat-widget-panel" data-chat-panel hidden>
    <header class="chat-widget-head">
      <div class="chat-widget-avatar" aria-hidden="true">
        <span class="chat-widget-mark">M</span>
      </div>
      <div class="chat-widget-meta">
        <h3>{{ t.chat.title }}</h3>
        <p class="chat-widget-status"><span class="chat-widget-dot"></span> {{ t.chat.status }}</p>
      </div>
      <button class="chat-widget-close" type="button" data-chat-close aria-label="{{ t.chat.closeLabel }}">×</button>
    </header>
    <div class="chat-widget-body">
      <div class="chat-bubble chat-bubble--in">
        <p>{{ t.chat.greeting }}</p>
        <p class="muted small">{{ t.chat.subline }}</p>
      </div>
      <p class="chat-widget-prompt">{{ t.chat.promptTitle }}</p>
      <div class="chat-widget-options">
        <button type="button" class="chat-option" data-chat-option="{{ t.chat.opt1Text }}">
          <span class="chat-option-emoji" aria-hidden="true">🚗</span> {{ t.chat.opt1 }}
        </button>
        <button type="button" class="chat-option" data-chat-option="{{ t.chat.opt2Text }}">
          <span class="chat-option-emoji" aria-hidden="true">🛬</span> {{ t.chat.opt2 }}
        </button>
        <button type="button" class="chat-option" data-chat-option="{{ t.chat.opt3Text }}">
          <span class="chat-option-emoji" aria-hidden="true">💼</span> {{ t.chat.opt3 }}
        </button>
        <button type="button" class="chat-option" data-chat-option="{{ t.chat.opt4Text }}">
          <span class="chat-option-emoji" aria-hidden="true">💬</span> {{ t.chat.opt4 }}
        </button>
      </div>
    </div>
    <footer class="chat-widget-foot">
      <p class="muted small">{{ t.chat.handoff }}</p>
    </footer>
  </div>
</div>
