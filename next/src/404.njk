---
permalink: "/404.html"
eleventyExcludeFromCollections: true
lang: "en"
title: "404 · Morrison Premium Transfer"
description: "This route point doesn't exist. Use the links below to get back on the map."
---
{%- set t = i18n[lang] -%}
<!DOCTYPE html>
<html lang="{{ t.htmlLang }}">
<head>
{% include "partials/head.njk" %}
<style>
  /* Initial state — show english, JS swaps for matching browser lang */
  [data-i18n-block]:not([data-i18n-default]) { display: none; }
</style>
</head>
<body>
{% include "partials/header.njk" %}
<main id="main">
<section class="section" style="min-height: 60vh; display: flex; align-items: center;">
  <div class="container container--narrow" style="text-align: center;">
    <p class="kicker">404</p>
    <h1 class="num-lg" style="font-family: var(--mono); font-size: clamp(5rem, 14vw, 9rem); margin: 1rem 0; letter-spacing: -0.04em;">404</h1>

    <div data-i18n-block data-i18n-lang="en" data-i18n-default>
      <h2 style="margin-bottom: 1rem;">This point isn't on the route.</h2>
      <p class="lead muted" style="max-width: 520px; margin: 0 auto 2rem;">The page you're looking for moved, was renamed, or never existed. Below are the most-used directions back to traffic.</p>
    </div>
    <div data-i18n-block data-i18n-lang="ru">
      <h2 style="margin-bottom: 1rem;">Эта точка не на маршруте.</h2>
      <p class="lead muted" style="max-width: 520px; margin: 0 auto 2rem;">Страница, которую вы ищете, переехала, была переименована или никогда не существовала. Ниже — самые частые направления обратно в трафик.</p>
    </div>
    <div data-i18n-block data-i18n-lang="pt">
      <h2 style="margin-bottom: 1rem;">Este ponto não está na rota.</h2>
      <p class="lead muted" style="max-width: 520px; margin: 0 auto 2rem;">A página que você procura mudou, foi renomeada ou nunca existiu. Abaixo, os caminhos mais usados de volta para o tráfego.</p>
    </div>

    <div class="bento" style="text-align: left;" data-i18n-bento>
      <a class="bento-cell bento-cell--span-3 bento-cell--row-2 bento-cell--photo bento-photo--brazil" data-i18n-href href="/en/">
        <div class="bento-bg"></div>
        <div class="bento-cell-content">
          <p class="eyebrow" data-i18n-key="home">Home</p>
          <h3 data-i18n-key="homeTitle">Back to the front page.</h3>
          <span class="bento-cta" data-i18n-key="open">Open</span>
        </div>
      </a>
      <a class="bento-cell bento-cell--span-3" data-i18n-href href="/en/routes/">
        <p class="eyebrow" data-i18n-key="routes">Routes</p>
        <h3 data-i18n-key="routesTitle">10 priced legs across Brazil &amp; Mercosur.</h3>
        <span class="bento-cta" data-i18n-key="seeRoutes">See routes</span>
      </a>
      <a class="bento-cell bento-cell--span-2 bento-cell--dark" data-i18n-href href="/en/contact/">
        <p class="eyebrow" data-i18n-key="contact">Contact</p>
        <h3 data-i18n-key="contactTitle">One-minute brief form.</h3>
        <span class="bento-cta" data-i18n-key="openForm">Open form</span>
      </a>
      <a class="bento-cell" href="https://wa.me/5513996532915" target="_blank" rel="noopener">
        <p class="eyebrow">WhatsApp</p>
        <h3 data-i18n-key="fastest">Fastest reply.</h3>
        <span class="bento-cta" data-i18n-key="open">Open</span>
      </a>
    </div>

    <p class="muted small" style="margin-top: 2.4rem;">
      <span data-i18n-block data-i18n-lang="en" data-i18n-default>Or pick a language:</span>
      <span data-i18n-block data-i18n-lang="ru">Или выберите язык:</span>
      <span data-i18n-block data-i18n-lang="pt">Ou escolha o idioma:</span>
      <a href="/ru/">Русский</a> · <a href="/pt/">Português</a> · <a href="/en/">English</a>
    </p>
  </div>
</section>
</main>
<script>
  // Detect preferred language from localStorage or navigator and swap blocks
  (function () {
    try {
      var stored = localStorage.getItem('preferredLanguage');
      var browserLang = (navigator.languages || [navigator.language || 'en'])[0].toLowerCase().split('-')[0];
      var lang = ['ru', 'pt', 'en'].indexOf(stored) >= 0 ? stored
               : ['ru', 'pt'].indexOf(browserLang) >= 0 ? browserLang : 'en';
      document.querySelectorAll('[data-i18n-block]').forEach(function (el) {
        el.style.display = el.dataset.i18nLang === lang ? '' : 'none';
      });
      document.querySelectorAll('[data-i18n-href]').forEach(function (el) {
        var href = el.getAttribute('href') || '';
        el.setAttribute('href', href.replace(/^\/(?:ru|pt|en)\//, '/' + lang + '/'));
      });
      var i18nText = {
        ru: { home: 'Главная', homeTitle: 'На главную.', open: 'Открыть',
              routes: 'Маршруты', routesTitle: '10 маршрутов с ценой по Бразилии и Mercosur.', seeRoutes: 'Маршруты',
              contact: 'Контакты', contactTitle: 'Форма-бриф за минуту.', openForm: 'Открыть форму',
              fastest: 'Быстрее всего.' },
        pt: { home: 'Início', homeTitle: 'Voltar ao início.', open: 'Abrir',
              routes: 'Rotas', routesTitle: '10 rotas com preço pelo Brasil e Mercosul.', seeRoutes: 'Ver rotas',
              contact: 'Contato', contactTitle: 'Formulário em um minuto.', openForm: 'Abrir formulário',
              fastest: 'Resposta mais rápida.' },
        en: { home: 'Home', homeTitle: 'Back to the front page.', open: 'Open',
              routes: 'Routes', routesTitle: '10 priced legs across Brazil & Mercosur.', seeRoutes: 'See routes',
              contact: 'Contact', contactTitle: 'One-minute brief form.', openForm: 'Open form',
              fastest: 'Fastest reply.' }
      };
      var dict = i18nText[lang] || i18nText.en;
      document.querySelectorAll('[data-i18n-key]').forEach(function (el) {
        var k = el.dataset.i18nKey;
        if (dict[k]) el.textContent = dict[k];
      });
      document.documentElement.lang = lang === 'pt' ? 'pt-BR' : lang;
    } catch (e) { /* keep default English */ }
  })();
</script>
{% include "partials/footer.njk" %}
<script src="/assets/script.js"></script>
</body>
</html>
