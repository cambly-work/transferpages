---
pagination:
  data: fleet.classes
  size: 1
  alias: veh
permalink: "/es/fleet/{{ veh.id }}/index.html"
eleventyComputed:
  title: "{{ veh.nameEs }} · flota | Morrison Premium Transfer"
  description: "{{ veh.nameEs }} en Morrison: {{ veh.pax }} plazas, {{ veh.bags }} maletas. {{ veh.forEs }}"
  slug: "fleet/{{ veh.id }}"
schema: "Service"
serviceType: "Private transfer · {veh.nameEs}"
---
<section class="hero">
  <div class="container container--narrow">
    <p class="kicker reveal-up">Flota · {{ veh.nameEs }}</p>
    <h1 class="reveal-up">{{ veh.nameEs }}.</h1>
    <p class="lead reveal-up">{{ veh.forEs }}</p>
    <dl class="metric-strip reveal-up">
      <div><dt>Pasajeros</dt><dd><span class="num">{{ veh.pax }}</span></dd></div>
      <div><dt>Equipaje</dt><dd><span class="num">{{ veh.bags }}</span><span class="unit">maletas</span></dd></div>
      <div><dt>Clase</dt><dd>{{ veh.id | upper }}</dd></div>
    </dl>
  </div>
</section>

<section class="fleet-illustration">
  <div class="container container--narrow">
    <img src="/assets/images/fleet-{{ veh.id }}.svg" alt="{{ veh.nameEs }}" loading="lazy" class="fleet-illustration-img">
  </div>
</section>

<section class="section">
  <div class="container container--narrow">
    <h2>Modelos típicos</h2>
    <p class="lead">{{ veh.examplesEs }}</p>
    <p class="muted small">El modelo exacto se confirma al reservar según región y disponibilidad.</p>

    <h2 style="margin-top: 3rem;">Qué hay dentro</h2>
    <p>{{ veh.featuresEs }}</p>

    <h2 style="margin-top: 3rem;">Para qué se usa</h2>
    <ul class="checklist">
      <li>{{ veh.forEs }}</li>
      <li>Recepciones en aeropuerto y continuación interurbana</li>
      <li>Rutas de negocios con horarios acordados</li>
      <li>Tramos internacionales por el Mercosur (con documentación)</li>
    </ul>
  </div>
</section>

<section class="section section--bg-soft">
  <div class="container container--narrow">
    <h2 style="text-align: center;">Comparar con otras clases</h2>
    <div class="fleet-compact-grid">
      {%- for other in fleet.classes %}
      {%- if other.id != veh.id %}
      <a class="fleet-compact-card" href="/es/fleet/{{ other.id }}/">
        <h3>{{ other.nameEs }}</h3>
        <p class="muted small num">{{ other.pax }} plazas · {{ other.bags }} maletas</p>
      </a>
      {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

<section class="cta-strip">
  <div class="container container--narrow">
    <h2>¿Vas con esta clase?</h2>
    <div class="cta-strip-actions">
      <a class="btn btn-dark btn-arrow" href="/es/contact/?vehicle={{ veh.id }}">Pedir cotización</a>
      <a class="btn btn-secondary" href="{{ site.contacts.whatsappUrl }}" target="_blank" rel="noopener">WhatsApp</a>
    </div>
  </div>
</section>
